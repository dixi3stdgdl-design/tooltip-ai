<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="TooltipAI"
           Manufacturer="TooltipAI"
           Version="1.0.0"
           UpgradeCode="12345678-1234-1234-1234-123456789012"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of TooltipAI is already installed." />
    <FeatureRef Id="ProductFeature" />

    <!-- Icon -->
    <Icon Id="TooltipAIIcon" SourceFile="$(var.PublishDir)\TooltipAI.Tray.exe" />
    <Property Id="ARPPRODUCTICON" Value="TooltipAIIcon" />

    <!-- Features -->
    <Feature Id="ProductFeature" Title="TooltipAI" Level="1">
      <ComponentRef Id="ServiceComponent" />
      <ComponentRef Id="TrayComponent" />
      <ComponentRef Id="ConfigComponent" />
      <Feature Id="AutoStartFeature" Title="Auto-start with Windows" Level="1">
        <ComponentRef Id="AutoStartComponent" />
      </Feature>
      <Feature Id="SilentModeFeature" Title="Silent Mode (no UI)" Level="1">
        <ComponentRef Id="SilentModeComponent" />
      </Feature>
      <Feature Id="EnterpriseConfigFeature" Title="Enterprise Configuration" Level="1">
        <ComponentRef Id="EnterpriseConfigComponent" />
      </Feature>
    </Feature>

    <!-- Components -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="ServiceComponent" Guid="11111111-1111-1111-1111-111111111111">
        <File Id="ServiceExe" Source="$(var.PublishDir)\TooltipAI.Service.exe" />
        <ServiceInstall Id="ServiceInstaller"
                        Type="ownProcess"
                        Start="auto"
                        ErrorControl="normal"
                        Name="TooltipAIService"
                        DisplayName="TooltipAI Service"
                        Description="TooltipAI background service for UI element detection" />
        <ServiceControl Id="ServiceControl"
                        Name="TooltipAIService"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>

      <Component Id="TrayComponent" Guid="22222222-2222-2222-2222-222222222222">
        <File Id="TrayExe" Source="$(var.PublishDir)\TooltipAI.Tray.exe" />
        <Shortcut Id="StartMenuShortcut"
                  Directory="ProgramMenuFolder"
                  Target="[!ServiceExe]"
                  Name="TooltipAI"
                  Description="TooltipAI - Intelligent Tooltip System"
                  WorkingDirectory="INSTALLFOLDER" />
      </Component>

      <Component Id="ConfigComponent" Guid="33333333-3333-3333-3333-333333333333">
        <File Id="RulesJson" Source="$(var.PublishDir)\rules.json" />
        <File Id="SettingsJson" Source="$(var.PublishDir)\settings.json" />
      </Component>

      <Component Id="AutoStartComponent" Guid="44444444-4444-4444-4444-444444444444">
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run"
                       Name="TooltipAI"
                       Type="string"
                       Value="[INSTALLFOLDER]TooltipAI.Tray.exe"
                       KeyPath="yes" />
      </Component>

      <Component Id="SilentModeComponent" Guid="55555555-5555-5555-5555-555555555555">
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\TooltipAI"
                       Name="SilentMode"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>

      <Component Id="EnterpriseConfigComponent" Guid="66666666-6666-6666-6666-666666666666">
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\TooltipAI"
                       Name="EnterpriseManaged"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Directories -->
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="INSTALLFOLDER" Name="TooltipAI" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuTooltipAI" Name="TooltipAI" />
    </StandardDirectory>
  </Package>
</Wix>
