<Window x:Class="TooltipAI.UI.Views.PrivacySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Privacy Settings" 
        Height="450" Width="500">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Privacy Settings" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Settings Panel -->
        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Global Enable -->
                <CheckBox x:Name="ChkEnableAgent" 
                          Content="Enable Tooltip AI"
                          IsChecked="True"
                          Margin="0,0,0,10"/>
                
                <Separator Margin="0,5,0,10"/>

                <!-- AI Enrichment -->
                <CheckBox x:Name="ChkAIEnrichment"
                          Content="AI Enrichment (cloud)"
                          Margin="0,0,0,5"/>
                <TextBlock Text="Sends anonymous context to improve tooltips"
                           Foreground="Gray" Margin="20,0,0,10"
                           TextWrapping="Wrap"/>

                <!-- Telemetry -->
                <CheckBox x:Name="ChkTelemetry"
                          Content="Usage Analytics - anonymous telemetry"
                          Margin="0,0,0,5"/>
                <TextBlock Text="Help improve Tooltip AI by sending anonymous usage data"
                           Foreground="Gray" Margin="20,0,0,10"
                           TextWrapping="Wrap"/>

                <!-- Local Only Mode -->
                <CheckBox x:Name="ChkLocalOnly"
                          Content="Local Only Mode - no cloud communication"
                          IsChecked="True"
                          Margin="0,0,0,5"/>
                <TextBlock Text="All processing stays on your device"
                           Foreground="Gray" Margin="20,0,0,15"
                           TextWrapping="Wrap"/>

                <Separator Margin="0,5,0,10"/>

                <!-- App Blacklist -->
                <TextBlock Text="App Blacklist:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ListBox x:Name="LstBlacklist" 
                         Height="100"
                         Margin="0,0,0,5"/>
                
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtBlacklistApp" 
                             Grid.Column="0"
                             Margin="0,0,5,0"/>
                    <Button x:Name="BtnAddToBlacklist"
                            Grid.Column="1"
                            Content="Add"
                            Width="60"
                            Click="BtnAddToBlacklist_Click"/>
                </Grid>

                <Button x:Name="BtnRemoveFromBlacklist"
                        Content="Remove Selected"
                        HorizontalAlignment="Left"
                        Click="BtnRemoveFromBlacklist_Click"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnSave" 
                    Content="Save" 
                    Width="80" 
                    Margin="0,0,10,0"
                    Click="BtnSave_Click"/>
            <Button x:Name="BtnReset" 
                    Content="Reset to Defaults" 
                    Width="120"
                    Click="BtnReset_Click"/>
        </StackPanel>
    </Grid>
</Window>
