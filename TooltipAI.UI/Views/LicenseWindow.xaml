<Window x:Class="TooltipAI.UI.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License Activation" 
        Height="350" Width="450">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="License Activation" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Current Status -->
        <TextBlock Grid.Row="1" Text="Current License" 
                   FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
        <Grid Grid.Row="1" Margin="0,28,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Status:" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtStatus" Text="Not Activated"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Tier:" FontWeight="SemiBold" Margin="0,5,0,0"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtTier" Text="Free" Margin="0,5,0,0"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Expires:" FontWeight="SemiBold" Margin="0,5,0,0"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtExpiry" Text="N/A" Margin="0,5,0,0"/>
        </Grid>

        <!-- License Key Input -->
        <TextBlock Grid.Row="2" Text="Activate License" 
                   FontWeight="SemiBold" FontSize="14" Margin="0,15,0,8"/>
        <StackPanel Grid.Row="2" Margin="0,28,0,0">
            <TextBlock Text="Enter your license key:" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtLicenseKey" Height="32" FontFamily="Consolas"/>
        </StackPanel>

        <!-- Usage Info (Free Tier) -->
        <TextBlock Grid.Row="3" Text="Usage" 
                   FontWeight="SemiBold" FontSize="14" Margin="0,15,0,8"/>
        <Grid Grid.Row="3" Margin="0,28,0,0" x:Name="GrpUsage">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Today:" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtUsage" Text="0/10 tooltips"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Remaining:" FontWeight="SemiBold" Margin="0,5,0,0"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtRemaining" Text="10 tooltips" Margin="0,5,0,0"/>
        </Grid>

        <!-- Message -->
        <TextBlock Grid.Row="4" x:Name="TxtMessage" 
                   Foreground="Green"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnActivate" 
                    Content="Activate" 
                    Width="100" Height="32"
                    Margin="0,0,10,0"
                    Click="BtnActivate_Click"/>
            <Button x:Name="BtnDeactivate" 
                    Content="Deactivate" 
                    Width="100" Height="32"
                    Margin="0,0,10,0"
                    Click="BtnDeactivate_Click"
                    IsEnabled="False"/>
            <Button x:Name="BtnClose" 
                    Content="Close" 
                    Width="80" Height="32"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
