<Window x:Class="TooltipAI.UI.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License Activation" 
        Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="License Activation" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Current Status -->
        <GroupBox Grid.Row="1" Header="Current License" Margin="0,0,0,10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Status:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" x:Name="TxtStatus" Text="Not Activated"/>
                </Grid>
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Tier:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" x:Name="TxtTier" Text="Free"/>
                </Grid>
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Expires:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" x:Name="TxtExpiry" Text="N/A"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- License Key Input -->
        <GroupBox Grid.Row="2" Header="Activate License" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Enter your license key:" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtLicenseKey" 
                         Height="30"
                         FontFamily="Consolas"
                         CharacterCasing="Upper"/>
            </StackPanel>
        </GroupBox>

        <!-- Usage Info (Free Tier) -->
        <GroupBox Grid.Row="3" Header="Usage" Margin="0,0,0,10" x:Name="GrpUsage">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Today:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" x:Name="TxtUsage" Text="0/10 tooltips"/>
                </Grid>
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Remaining:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" x:Name="TxtRemaining" Text="10 tooltips"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Message -->
        <TextBlock Grid.Row="4" x:Name="TxtMessage" 
                   Foreground="Green"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnActivate" 
                    Content="Activate" 
                    Width="100" 
                    Height="30"
                    Margin="0,0,10,0"
                    Click="BtnActivate_Click"/>
            <Button x:Name="BtnDeactivate" 
                    Content="Deactivate" 
                    Width="100" 
                    Height="30"
                    Margin="0,0,10,0"
                    Click="BtnDeactivate_Click"
                    IsEnabled="False"/>
            <Button x:Name="BtnClose" 
                    Content="Close" 
                    Width="80" 
                    Height="30"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
