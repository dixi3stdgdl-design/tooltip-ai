<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="TooltipAI.UI.Views.TooltipOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="420" d:DesignHeight="360">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Glow border layer (outer halo) -->
        <Border x:Name="GlowBorder"
                Grid.RowSpan="2"
                CornerRadius="14"
                BorderThickness="2"
                Margin="-3"
                Opacity="0.5"
                IsHitTestVisible="False"/>

        <!-- Main content panel -->
        <Border x:Name="MainBorder"
                Grid.RowSpan="2"
                CornerRadius="12"
                BorderThickness="1.5"
                Padding="0"
                Opacity="0.97">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER: Category badge + Title -->
                <Grid Grid.Row="0" Padding="14,10,14,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Category badge -->
                    <Border x:Name="CategoryBadge"
                            CornerRadius="4"
                            Padding="6,3"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock x:Name="CategoryIcon"
                                       FontFamily="Consolas" FontSize="11"
                                       FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CategoryLabel"
                                       FontFamily="Consolas" FontSize="9"
                                       FontWeight="SemiBold" VerticalAlignment="Center"
                                       Opacity="0.9"/>
                        </StackPanel>
                    </Border>

                    <!-- Module / Process name -->
                    <TextBlock x:Name="TitleText"
                               Grid.Column="1"
                               FontFamily="Consolas" FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Separator line -->
                <Border Grid.Row="1" Height="1" Margin="14,0,14,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop x:Name="SepColor1" Color="#00FF88" Offset="0.3"/>
                            <GradientStop x:Name="SepColor2" Color="#00FF88" Offset="0.7"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- VISUALIZATION AREA: Canvas for waveform/spectrum/CV -->
                <Border x:Name="VizBorder"
                        Grid.Row="2"
                        Margin="14,6,14,6"
                        CornerRadius="6"
                        Padding="2"
                        MinHeight="80"
                        MaxHeight="140">
                    <Canvas x:Name="VizCanvas"
                            Background="Transparent"/>
                </Border>

                <!-- INFO PANELS: Structured data rows -->
                <StackPanel x:Name="InfoPanel"
                            Grid.Row="3"
                            Margin="14,0,14,0"
                            Spacing="2">

                    <!-- Gesture hint row -->
                    <Grid x:Name="GestureRow" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="GestureBadge"
                                CornerRadius="3"
                                Padding="4,1"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="GESTO"
                                       FontFamily="Consolas" FontSize="8"
                                       FontWeight="Bold"/>
                        </Border>
                        <TextBlock x:Name="GestureText"
                                   Grid.Column="1"
                                   FontFamily="Consolas" FontSize="9"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Quality tip row -->
                    <Grid x:Name="TipRow" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="TipBadge"
                                CornerRadius="3"
                                Padding="4,1"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="TIP"
                                       FontFamily="Consolas" FontSize="8"
                                       FontWeight="Bold"/>
                        </Border>
                        <TextBlock x:Name="TipText"
                                   Grid.Column="1"
                                   FontFamily="Consolas" FontSize="9"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Move guide row -->
                    <Grid x:Name="GuideRow" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="GuideBadge"
                                CornerRadius="3"
                                Padding="4,1"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="GUIA"
                                       FontFamily="Consolas" FontSize="8"
                                       FontWeight="Bold"/>
                        </Border>
                        <TextBlock x:Name="GuideText"
                                   Grid.Column="1"
                                   FontFamily="Consolas" FontSize="9"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Data insight row -->
                    <Grid x:Name="InsightRow" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="InsightBadge"
                                CornerRadius="3"
                                Padding="4,1"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="DATOS"
                                       FontFamily="Consolas" FontSize="8"
                                       FontWeight="Bold"/>
                        </Border>
                        <TextBlock x:Name="InsightText"
                                   Grid.Column="1"
                                   FontFamily="Consolas" FontSize="9"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- FOOTER: Context + Description -->
                <StackPanel x:Name="FooterPanel"
                            Grid.Row="4"
                            Margin="14,4,14,10"
                            Spacing="2">

                    <TextBlock x:Name="ContextText"
                               FontFamily="Consolas" FontSize="8.5"
                               Foreground="#80FFFFFF"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Opacity="0.7"/>

                    <TextBlock x:Name="DescriptionText"
                               FontFamily="Consolas" FontSize="8.5"
                               Foreground="#60FFFFFF"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Opacity="0.6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Noise texture overlay layer -->
        <Canvas x:Name="NoiseOverlay"
                Grid.RowSpan="2"
                IsHitTestVisible="False"
                Opacity="0.4"/>
    </Grid>
</UserControl>
